{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyAllRegionsExceptMumbai",
      "Effect": "Deny",
      "NotAction": [
        "iam:*",
        "route53:*",
        "acm:*",
        "sts:*",
        "cloudfront:*",
        "organizations:*",
        "support:*"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": "ap-south-1"
        }
      }
    },
    {
      "Sid": "TerraformS3Backend",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:GetBucketVersioning"
      ],
      "Resource": "arn:aws:s3:::terraform-aws-enterprise-state"
    },
    {
      "Sid": "TerraformS3BackendObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::terraform-aws-enterprise-state/*"
    },
    {
      "Sid": "TerraformDynamoDBLocking",
      "Effect": "Allow",
      "Action": [
        "dynamodb:DescribeTable",
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:DeleteItem"
      ],
      "Resource": "arn:aws:dynamodb:ap-south-1:*:table/terraform-state-lock"
    },
    {
      "Sid": "STSCallerIdentity",
      "Effect": "Allow",
      "Action": "sts:GetCallerIdentity",
      "Resource": "*"
    },
    {
      "Sid": "EC2DescribeGlobal",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeVpcs",
        "ec2:DescribeVpcAttribute",
        "ec2:DescribeSubnets",
        "ec2:DescribeInternetGateways",
        "ec2:DescribeRouteTables",
        "ec2:DescribeNetworkAcls",
        "ec2:DescribeSecurityGroups",
        "ec2:DescribeSecurityGroupRules",
        "ec2:DescribeAddresses",
        "ec2:DescribeNatGateways",
        "ec2:DescribeVpcEndpoints",
        "ec2:DescribeVpcEndpointServices",
        "ec2:DescribeFlowLogs",
        "ec2:DescribeAvailabilityZones",
        "ec2:DescribeRegions"
      ],
      "Resource": "*"
    },
    {
      "Sid": "EC2VPCOperations",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateVpc",
        "ec2:DeleteVpc",
        "ec2:ModifyVpcAttribute"
      ],
      "Resource": "arn:aws:ec2:ap-south-1:*:vpc/*",
      "Condition": {
        "StringEquals": {
          "aws:RequestTag/Project": "cloud-foundation"
        }
      }
    },
    {
      "Sid": "EC2SubnetOperations",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateSubnet",
        "ec2:DeleteSubnet",
        "ec2:ModifySubnetAttribute"
      ],
      "Resource": "arn:aws:ec2:ap-south-1:*:subnet/*",
      "Condition": {
        "StringEquals": {
          "aws:RequestTag/Project": "cloud-foundation"
        }
      }
    },
    {
      "Sid": "EC2InternetGatewayOperations",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateInternetGateway",
        "ec2:DeleteInternetGateway",
        "ec2:AttachInternetGateway",
        "ec2:DetachInternetGateway"
      ],
      "Resource": [
        "arn:aws:ec2:ap-south-1:*:internet-gateway/*",
        "arn:aws:ec2:ap-south-1:*:vpc/*"
      ]
    },
    {
      "Sid": "EC2RouteTableOperations",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateRouteTable",
        "ec2:DeleteRouteTable",
        "ec2:AssociateRouteTable",
        "ec2:DisassociateRouteTable",
        "ec2:CreateRoute",
        "ec2:DeleteRoute",
        "ec2:ReplaceRoute"
      ],
      "Resource": [
        "arn:aws:ec2:ap-south-1:*:route-table/*",
        "arn:aws:ec2:ap-south-1:*:vpc/*",
        "arn:aws:ec2:ap-south-1:*:subnet/*",
        "arn:aws:ec2:ap-south-1:*:natgateway/*",
        "arn:aws:ec2:ap-south-1:*:internet-gateway/*"
      ]
    },
    {
      "Sid": "EC2NetworkACLOperations",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateNetworkAcl",
        "ec2:DeleteNetworkAcl",
        "ec2:CreateNetworkAclEntry",
        "ec2:ReplaceNetworkAclEntry",
        "ec2:DeleteNetworkAclEntry"
      ],
      "Resource": [
        "arn:aws:ec2:ap-south-1:*:network-acl/*",
        "arn:aws:ec2:ap-south-1:*:vpc/*",
        "arn:aws:ec2:ap-south-1:*:subnet/*"
      ]
    },
    {
      "Sid": "EC2SecurityGroupOperations",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateSecurityGroup",
        "ec2:DeleteSecurityGroup",
        "ec2:AuthorizeSecurityGroupIngress",
        "ec2:AuthorizeSecurityGroupEgress",
        "ec2:RevokeSecurityGroupIngress",
        "ec2:RevokeSecurityGroupEgress"
      ],
      "Resource": [
        "arn:aws:ec2:ap-south-1:*:security-group/*",
        "arn:aws:ec2:ap-south-1:*:vpc/*"
      ]
    },
    {
      "Sid": "EC2ElasticIPOperations",
      "Effect": "Allow",
      "Action": [
        "ec2:AllocateAddress",
        "ec2:ReleaseAddress",
        "ec2:AssociateAddress",
        "ec2:DisassociateAddress"
      ],
      "Resource": "*"
    },
    {
      "Sid": "EC2NATGatewayOperations",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateNatGateway",
        "ec2:DeleteNatGateway"
      ],
      "Resource": [
        "arn:aws:ec2:ap-south-1:*:natgateway/*",
        "arn:aws:ec2:ap-south-1:*:subnet/*",
        "arn:aws:ec2:ap-south-1:*:elastic-ip/*"
      ]
    },
    {
      "Sid": "EC2VPCEndpointOperations",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateVpcEndpoint",
        "ec2:DeleteVpcEndpoint",
        "ec2:ModifyVpcEndpoint",
        "ec2:AssociateVpcEndpointRouteTable",
        "ec2:DisassociateVpcEndpointRouteTable"
      ],
      "Resource": [
        "arn:aws:ec2:ap-south-1:*:vpc-endpoint/*",
        "arn:aws:ec2:ap-south-1:*:vpc/*",
        "arn:aws:ec2:ap-south-1:*:subnet/*",
        "arn:aws:ec2:ap-south-1:*:route-table/*",
        "arn:aws:ec2:ap-south-1:*:security-group/*"
      ]
    },
    {
      "Sid": "EC2FlowLogsOperations",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateFlowLogs",
        "ec2:DeleteFlowLogs"
      ],
      "Resource": [
        "arn:aws:ec2:ap-south-1:*:vpc/*",
        "arn:aws:ec2:ap-south-1:*:flow-log/*"
      ]
    },
    {
      "Sid": "EC2TaggingOnCreate",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateTags"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestTag/Project": "cloud-foundation"
        }
      }
    },
    {
      "Sid": "EC2TaggingOnExisting",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateTags",
        "ec2:DeleteTags"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/Project": "cloud-foundation"
        }
      }
    },
    {
      "Sid": "RDSSubnetGroupOperations",
      "Effect": "Allow",
      "Action": [
        "rds:CreateDBSubnetGroup",
        "rds:DeleteDBSubnetGroup",
        "rds:ModifyDBSubnetGroup",
        "rds:AddTagsToResource",
        "rds:RemoveTagsFromResource",
        "rds:ListTagsForResource"
      ],
      "Resource": "arn:aws:rds:ap-south-1:*:subgrp:cloud-foundation-*-db-subnet-group"
    },
    {
      "Sid": "RDSDescribeGlobal",
      "Effect": "Allow",
      "Action": [
        "rds:DescribeDBSubnetGroups"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CloudWatchLogsDescribe",
      "Effect": "Allow",
      "Action": [
        "logs:DescribeLogGroups",
        "logs:DescribeLogStreams"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CloudWatchLogsOperations",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:DeleteLogGroup",
        "logs:PutRetentionPolicy",
        "logs:DeleteRetentionPolicy",
        "logs:TagResource",
        "logs:UntagResource",
        "logs:ListTagsForResource"
      ],
      "Resource": [
        "arn:aws:logs:ap-south-1:*:log-group:/aws/vpc-flow-logs/cloud-foundation-*",
        "arn:aws:logs:ap-south-1:*:log-group:/ecs/cloud-foundation-*"
      ]
    },
    {
      "Sid": "ECRRepositoryOperations",
      "Effect": "Allow",
      "Action": [
        "ecr:CreateRepository",
        "ecr:DeleteRepository",
        "ecr:DescribeRepositories",
        "ecr:GetRepositoryPolicy",
        "ecr:SetRepositoryPolicy",
        "ecr:ListTagsForResource",
        "ecr:TagResource",
        "ecr:UntagResource",
        "ecr:PutImageScanningConfiguration"
      ],
      "Resource": "arn:aws:ecr:ap-south-1:*:repository/cloud-foundation-*"
    },
    {
      "Sid": "ECSDescribeGlobal",
      "Effect": "Allow",
      "Action": [
        "ecs:ListClusters",
        "ecs:ListServices",
        "ecs:ListTaskDefinitions",
        "ecs:ListTaskDefinitionFamilies"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ECSClusterOperations",
      "Effect": "Allow",
      "Action": [
        "ecs:CreateCluster",
        "ecs:DeleteCluster",
        "ecs:DescribeClusters",
        "ecs:PutClusterSettings"
      ],
      "Resource": "arn:aws:ecs:ap-south-1:*:cluster/cloud-foundation-*-cluster"
    },
    {
      "Sid": "ECSServiceOperations",
      "Effect": "Allow",
      "Action": [
        "ecs:CreateService",
        "ecs:DeleteService",
        "ecs:UpdateService",
        "ecs:DescribeServices"
      ],
      "Resource": "arn:aws:ecs:ap-south-1:*:service/cloud-foundation-*-cluster/cloud-foundation-*-bg-service"
    },
    {
      "Sid": "ECSTaskDefinitionOperations",
      "Effect": "Allow",
      "Action": [
        "ecs:RegisterTaskDefinition",
        "ecs:DeregisterTaskDefinition",
        "ecs:DescribeTaskDefinition"
      ],
      "Resource": "arn:aws:ecs:ap-south-1:*:task-definition/cloud-foundation-*-task:*"
    },
    {
      "Sid": "ECSTagging",
      "Effect": "Allow",
      "Action": [
        "ecs:TagResource",
        "ecs:UntagResource",
        "ecs:ListTagsForResource"
      ],
      "Resource": "*"
    },
    {
      "Sid": "SSMParametersOperations",
      "Effect": "Allow",
      "Action": [
        "ssm:PutParameter",
        "ssm:DeleteParameter",
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath",
        "ssm:GetParameterHistory",
        "ssm:AddTagsToResource",
        "ssm:RemoveTagsFromResource",
        "ssm:ListTagsForResource"
      ],
      "Resource": "arn:aws:ssm:ap-south-1:*:parameter/cloud-foundation/*"
    },
    {
      "Sid": "SSMParametersDescribe",
      "Effect": "Allow",
      "Action": [
        "ssm:DescribeParameters"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ELBv2DescribeGlobal",
      "Effect": "Allow",
      "Action": [
        "elasticloadbalancing:DescribeLoadBalancers",
        "elasticloadbalancing:DescribeLoadBalancerAttributes",
        "elasticloadbalancing:DescribeTargetGroups",
        "elasticloadbalancing:DescribeTargetGroupAttributes",
        "elasticloadbalancing:DescribeTargetHealth",
        "elasticloadbalancing:DescribeListeners",
        "elasticloadbalancing:DescribeListenerAttributes",
        "elasticloadbalancing:DescribeListenerCertificates",
        "elasticloadbalancing:DescribeSSLPolicies",
        "elasticloadbalancing:DescribeRules",
        "elasticloadbalancing:DescribeTags"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ELBv2Operations",
      "Effect": "Allow",
      "Action": [
        "elasticloadbalancing:CreateLoadBalancer",
        "elasticloadbalancing:DeleteLoadBalancer",
        "elasticloadbalancing:ModifyLoadBalancerAttributes"
      ],
      "Resource": "arn:aws:elasticloadbalancing:ap-south-1:*:loadbalancer/app/cloud-foundation-alb/*"
    },
    {
      "Sid": "ELBv2TargetGroupOperations",
      "Effect": "Allow",
      "Action": [
        "elasticloadbalancing:CreateTargetGroup",
        "elasticloadbalancing:DeleteTargetGroup",
        "elasticloadbalancing:ModifyTargetGroupAttributes"
      ],
      "Resource": "arn:aws:elasticloadbalancing:ap-south-1:*:targetgroup/cloud-foundation-tg-*/*"
    },
    {
      "Sid": "ELBv2ListenerOperations",
      "Effect": "Allow",
      "Action": [
        "elasticloadbalancing:CreateListener",
        "elasticloadbalancing:DeleteListener",
        "elasticloadbalancing:ModifyListener"
      ],
      "Resource": [
        "arn:aws:elasticloadbalancing:ap-south-1:*:listener/app/cloud-foundation-alb/*",
        "arn:aws:elasticloadbalancing:ap-south-1:*:loadbalancer/app/cloud-foundation-alb/*",
        "arn:aws:elasticloadbalancing:ap-south-1:*:targetgroup/cloud-foundation-tg-*/*"
      ]
    },
    {
      "Sid": "ELBv2Tagging",
      "Effect": "Allow",
      "Action": [
        "elasticloadbalancing:AddTags",
        "elasticloadbalancing:RemoveTags"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AppAutoscalingOperations",
      "Effect": "Allow",
      "Action": [
        "application-autoscaling:RegisterScalableTarget",
        "application-autoscaling:DeregisterScalableTarget",
        "application-autoscaling:DescribeScalableTargets",
        "application-autoscaling:PutScalingPolicy",
        "application-autoscaling:DeleteScalingPolicy",
        "application-autoscaling:DescribeScalingPolicies",
        "application-autoscaling:ListTagsForResource"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CodeDeployDescribeGlobal",
      "Effect": "Allow",
      "Action": [
        "codedeploy:ListApplications",
        "codedeploy:ListDeploymentGroups",
        "codedeploy:ListDeploymentConfigs"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CodeDeployApplicationOperations",
      "Effect": "Allow",
      "Action": [
        "codedeploy:CreateApplication",
        "codedeploy:DeleteApplication",
        "codedeploy:GetApplication",
        "codedeploy:UpdateApplication"
      ],
      "Resource": "arn:aws:codedeploy:ap-south-1:*:application:cloud-foundation-*-ecs-app"
    },
    {
      "Sid": "CodeDeployDeploymentGroupOperations",
      "Effect": "Allow",
      "Action": [
        "codedeploy:CreateDeploymentGroup",
        "codedeploy:DeleteDeploymentGroup",
        "codedeploy:GetDeploymentGroup",
        "codedeploy:UpdateDeploymentGroup"
      ],
      "Resource": [
        "arn:aws:codedeploy:ap-south-1:*:application:cloud-foundation-*-ecs-app",
        "arn:aws:codedeploy:ap-south-1:*:deploymentgroup:cloud-foundation-*-ecs-app/cloud-foundation-*-ecs-dg"
      ]
    },
    {
      "Sid": "CodeDeployDeploymentConfigGet",
      "Effect": "Allow",
      "Action": [
        "codedeploy:GetDeploymentConfig"
      ],
      "Resource": "arn:aws:codedeploy:ap-south-1:*:deploymentconfig:CodeDeployDefault.ECSAllAtOnce"
    },
    {
      "Sid": "CodeDeployTagging",
      "Effect": "Allow",
      "Action": [
        "codedeploy:TagResource",
        "codedeploy:UntagResource",
        "codedeploy:ListTagsForResource"
      ],
      "Resource": "*"
    },
    {
      "Sid": "IAMPolicyReadOnly",
      "Effect": "Allow",
      "Action": [
        "iam:GetPolicy",
        "iam:GetPolicyVersion",
        "iam:ListRoles",
        "iam:ListPolicies",
        "iam:ListPolicyVersions"
      ],
      "Resource": "arn:aws:iam::aws:policy/*"
    },
    {
      "Sid": "IAMRoleOperations",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:UpdateRole",
        "iam:TagRole",
        "iam:UntagRole",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:GetRolePolicy",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:ListAttachedRolePolicies",
        "iam:ListRolePolicies",
        "iam:ListRoleTags"
      ],
      "Resource": [
        "arn:aws:iam::*:role/cloud-foundation-*-vpc-flow-logs-role",
        "arn:aws:iam::*:role/cloud-foundation-*-ecs-exec-role",
        "arn:aws:iam::*:role/cloud-foundation-*-ecs-task-role",
        "arn:aws:iam::*:role/cloud-foundation-*-codedeploy-role"
      ]
    },
    {
      "Sid": "IAMPassRole",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::*:role/cloud-foundation-*-vpc-flow-logs-role",
        "arn:aws:iam::*:role/cloud-foundation-*-ecs-exec-role",
        "arn:aws:iam::*:role/cloud-foundation-*-ecs-task-role",
        "arn:aws:iam::*:role/cloud-foundation-*-codedeploy-role"
      ]
    }
  ]
}
